# DeepSeek V4 is used for answer generation / synthesis.
# Keep embeddings on a separate provider because PaperQA needs embeddings for retrieval.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
PQA_LLM_MODEL=deepseek/deepseek-v4-flash
PQA_SUMMARY_LLM_MODEL=deepseek/deepseek-v4-flash
PQA_AGENT_LLM_MODEL=deepseek/deepseek-v4-flash
PQA_ENRICHMENT_LLM_MODEL=deepseek/deepseek-v4-flash
# Alternative stronger model for UI/CLI selection:
# PQA_LLM_MODEL=deepseek/deepseek-v4-pro
PQA_ROUTE_DEFAULT=auto
PQA_PAPER_MODE=direct
PQA_KNOWLEDGE_MODE=auto
PQA_CONTEXT_TOP_K=8
PQA_DOC_TOP_N=8
PQA_WIKI_TOP_K=4
PQA_SYNTHESIS_LAYER=1
PQA_KNOWLEDGE_TEMPERATURE=0.45
PQA_CHAT_TEMPERATURE=0.55
# Context budget — control how much evidence goes into each answer.
# Total char budget across all groups:
# PQA_CONTEXT_TOTAL_CHAR_BUDGET=20000
# Per-group item and char limits:
# PQA_CONTEXT_AGGREGATE_MAX_ITEMS=4
# PQA_CONTEXT_AGGREGATE_CHAR_BUDGET=4200
# PQA_CONTEXT_PAPER_PAGE_MAX_ITEMS=4
# PQA_CONTEXT_PAPER_PAGE_CHAR_BUDGET=3200
# PQA_CONTEXT_PAPER_EVIDENCE_MAX_ITEMS=8
# PQA_CONTEXT_PAPER_EVIDENCE_CHAR_BUDGET=9000
# PQA_CONTEXT_OTHER_WIKI_MAX_ITEMS=2
# PQA_CONTEXT_OTHER_WIKI_CHAR_BUDGET=1600

# LLM Wiki compiler budgets. These replace earlier fixed truncation behavior.
# Larger values preserve more detail but increase LLM tokens during Wiki compilation.
# Values below reflect the budgets used in the current Pro-generated wiki.
LLM_WIKI_PAPER_CHAR_BUDGET=18000
LLM_WIKI_AGGREGATE_CARD_CHAR_BUDGET=70000
LLM_WIKI_AGGREGATE_BATCH_CHAR_BUDGET=700000
LLM_WIKI_AGGREGATE_MERGE_CHAR_BUDGET=700000
LLM_WIKI_AGGREGATE_TIMEOUT=1800
LLM_WIKI_AGGREGATE_MAX_MERGE_ROUNDS=6
LLM_WIKI_MIN_AGGREGATE_CHARS=450
# Optional aggregate output caps (values from current Pro run):
# LLM_WIKI_MAX_CONCEPTS=160
# LLM_WIKI_MAX_METHODS=160
# LLM_WIKI_MAX_CLAIMS=320
# LLM_WIKI_MAX_SYNTHESES=120
# LLM_WIKI_MAX_OPEN_QUESTIONS=90

# Optional domain-specific auto-routing keywords (comma or pipe separated).
# When set, questions matching any keyword in auto mode will trigger knowledge retrieval.
# When unset, auto mode relies on explicit knowledge signals in the question text.
# PQA_DOMAIN_PATTERNS=fracture,reservoir,seismic,断层,储层,裂缝

# Optional: enable direct links from answer sources to Obsidian.
# First open ./wiki as a vault in Obsidian, then set the exact vault name shown by Obsidian.
# OBSIDIAN_VAULT_NAME=wiki
# OBSIDIAN_VAULT_ID=

# Embedding provider for indexing and retrieval.
# Example: ZhipuAI / BigModel embedding-3.
OPENAI_API_KEY=your_zhipu_embedding_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
PQA_EMBEDDING_MODEL=openai/embedding-3
PQA_EMBEDDING_DIMENSIONS=1024

# Optional advanced JSON configs passed into PaperQA/LiteLLM.
# PQA_LLM_CONFIG_JSON={}
# PQA_EMBEDDING_CONFIG_JSON={}
