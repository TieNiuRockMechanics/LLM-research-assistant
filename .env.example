# Option A: standard OpenAI-compatible settings
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Option B: Kimi / Moonshot chat models
MOONSHOT_API_KEY=your_kimi_api_key_here
OPENAI_BASE_URL=https://api.moonshot.cn/v1
PQA_LLM_MODEL=kimi-k2.5
PQA_SUMMARY_LLM_MODEL=kimi-k2.5

# PaperQA2 still needs an embedding provider for indexing/retrieval.
# Kimi's public docs currently show chat/files compatibility, so we keep
# embedding config explicit here instead of assuming it exists.
#
# Example with a second cloud embedding provider:
# PQA_EMBEDDING_MODEL=text-embedding-3-small
# PQA_EMBEDDING_CONFIG_JSON={"model_list":[{"model_name":"text-embedding-3-small","litellm_params":{"model":"text-embedding-3-small","api_key":"YOUR_EMBEDDING_KEY"}}]}
